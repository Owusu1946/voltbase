{
  "name": "voltbase-js",
  "version": "1.0.1",
  "description": "The official JavaScript SDK for Voltbase",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "voltbase",
    "sdk",
    "realtime",
    "storage",
    "database"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.9.0",
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.4",
    "@voltbase/constants": "workspace:*",
    "@voltbase/types": "workspace:*",
    "socket.io-client": "^4.8.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unrun": "^0.3.1",
    "uploadthing": "^7.7.4"
  }
}
